# ============================================
# Production-Grade Security Configuration
# ============================================
# Copy this file to .env and update with your actual values
# NEVER commit .env to version control

# ============================================
# Server Configuration
# ============================================
NODE_ENV=production
PORT=3001

# ============================================
# JWT Secrets (CRITICAL - Change in production!)
# ============================================
# Generate strong secrets using: openssl rand -base64 32
# Minimum 32 characters recommended
# These secrets sign and verify JWT tokens - if compromised, all tokens are invalid
ACCESS_TOKEN_SECRET=your_access_token_secret_min_32_characters_long_change_this_in_production
REFRESH_TOKEN_SECRET=your_refresh_token_secret_min_32_characters_long_change_this_in_production

# ============================================
# Database Configuration
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password

# ============================================
# CORS Configuration
# ============================================
# Comma-separated list of allowed origins
# In production, only include your actual frontend domains
# Example: https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ============================================
# Security Configuration
# ============================================
# Bcrypt salt rounds (10+ recommended for production)
# Higher = more secure but slower (10 is good balance)
BCRYPT_SALT_ROUNDS=10

# ============================================
# API Configuration
# ============================================
# Public API URL (used by frontend)
NEXT_PUBLIC_API_URL=http://localhost:3001

# ============================================
# Optional: Additional Security
# ============================================
# Rate limiting (if you want to override defaults)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100
# AUTH_RATE_LIMIT_MAX_REQUESTS=5

# ============================================
# Development Overrides
# ============================================
# For development, you can use:
# NODE_ENV=development
# ALLOWED_ORIGINS=http://localhost:3000
# NEXT_PUBLIC_API_URL=http://localhost:3001

